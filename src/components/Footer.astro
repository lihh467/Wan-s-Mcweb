---
import { websiteConfig } from '../config/website.config.js';
---

<footer class="footer">
    <div class="footer-container">
        <!-- 版权信息 -->
        <div class="footer-copyright">
            <p>{websiteConfig.footer.copyright}</p>
        </div>
        
        <!-- Power by 信息（版权信息请勿修改！！！） -->
        <div class="footer-powered">
            <p>Power by <a href="https://astro.js.cn/" class="powered-link">Astro</a>&<a href="https://github.com/wanwanjiean123" class="powered-link">Wan</a></p>
        </div>
        
        <!-- 自定义HTML内容 -->
        <div class="footer-custom">
            <div set:html={websiteConfig.footer.customHtml} />
        </div>
    </div>
</footer>

<style>
.footer {
    background: var(--glass-bg);
    backdrop-filter: var(--glass-backdrop);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
    margin: 4rem 2rem 2rem;
    padding: 1rem 0;
}

.footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0rem;
}

.footer-copyright {
    text-align: center;
    color: var(--color-text-light);
    font-size: 0.9rem;
}

.footer-custom {
    text-align: center;
    color: var(--color-text-light);
    font-size: 0.8rem;
}

.footer-powered {
    text-align: center;
    color: var(--color-text-light);
    font-size: 0.8rem;
}

.powered-link {
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.3s var(--ease-smooth);
}

.powered-link:hover {
    color: var(--color-primary-light);
    text-decoration: underline;
}

@media (max-width: 768px) {
    .footer {
        margin: 4rem 1rem 1rem;
        border-radius: var(--radius-lg);
    }
    
    .footer-container {
        padding: 0 1rem;
        gap: 0.75rem;
    }
}
</style>